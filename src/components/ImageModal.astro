---
---

<!-- Reusable site-wide image modal. Include this once (e.g. in Layout.astro). -->
<div
    id="image-modal"
    class="hidden fixed inset-0 bg-black bg-opacity-80 z-50 flex items-center justify-center p-6"
    role="dialog"
    aria-modal="true"
>
    <button
        id="modal-prev"
        class="hidden absolute left-4 md:left-6 top-1/2 -translate-y-1/2 text-white bg-black bg-opacity-50 rounded-full p-2 hover:bg-opacity-75"
        aria-label="Previous image"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18 9 12l6-6"/></svg>
    </button>

    <button
        id="modal-close"
        class="absolute top-6 right-6 text-white bg-black bg-opacity-50 rounded-full p-2 hover:bg-opacity-75"
        aria-label="Close image"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6L6 18"></path><path d="M6 6l12 12"></path></svg>
    </button>

    <img id="modal-img" src="" alt="" class="max-w-full max-h-full object-contain rounded" />

    <button
        id="modal-next"
        class="hidden absolute right-4 md:right-6 top-1/2 -translate-y-1/2 text-white bg-black bg-opacity-50 rounded-full p-2 hover:bg-opacity-75"
        aria-label="Next image"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
</div>

<!-- Tooltip for images -->
<div id="img-tooltip" class="hidden fixed z-60 bg-black text-white text-sm px-3 py-1 rounded pointer-events-none">View in Fullscreen</div>

<script is:inline>
    // Generic image modal wiring for any page. It will attach to images matching these selectors:
    //  - img[data-full]
    //  - img[data-modalable]
    //  - img.modal-image
    //  - img.clickable-hero
    // This keeps behaviour opt-in; add one of these to an image to enable the modal.

    const modal = document.getElementById('image-modal');
    const modalImg = document.getElementById('modal-img');
    const closeBtn = document.getElementById('modal-close');
    const prevBtn = document.getElementById('modal-prev');
    const nextBtn = document.getElementById('modal-next');
    const tooltip = document.getElementById('img-tooltip');
    const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    let galleryImages = [];
    let currentIndex = -1;
    const isProjectDetailPage = () => {
        // Base-path-safe detection for project detail pages (works for /projects/... and /<base>/projects/...).
        if (document.getElementById('project-hero')) return true;
        return /\/projects\/[^/]+\/?$/.test(window.location.pathname);
    };

    const updateNavButtons = () => {
        const showNav = galleryImages.length > 1;
        if (prevBtn) prevBtn.classList.toggle('hidden', !showNav);
        if (nextBtn) nextBtn.classList.toggle('hidden', !showNav);
    };

    const showImageAt = (index) => {
        if (!galleryImages.length || !modalImg) return;
        const normalized = (index + galleryImages.length) % galleryImages.length;
        currentIndex = normalized;
        const img = galleryImages[normalized];
        modalImg.src = img.dataset.full || img.src;
        modalImg.alt = img.alt || '';
        updateNavButtons();
    };

    const openModalForImage = (img) => {
        if (!modal || !modalImg) return;
        modal.classList.remove('hidden');

        // Determine gallery set: for project detail pages, include hero + all project article images.
        if (isProjectDetailPage()) {
            const hero = document.getElementById('project-hero');
            const articleImgs = Array.from(document.querySelectorAll('article img')).filter((i) => i.id !== 'modal-img');
            const set = [hero, ...articleImgs].filter(Boolean);
            galleryImages = Array.from(new Set(set));
        } else {
            galleryImages = [img];
        }

        const clickedIndex = galleryImages.indexOf(img);
        showImageAt(clickedIndex >= 0 ? clickedIndex : 0);

        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';
        if (closeBtn) closeBtn.focus();
    };

    const closeModal = () => {
        if (!modal || !modalImg) return;
        modal.classList.add('hidden');
        modalImg.src = '';
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        galleryImages = [];
        currentIndex = -1;
        updateNavButtons();
    };

    const showPrev = () => showImageAt(currentIndex - 1);
    const showNext = () => showImageAt(currentIndex + 1);

    // Wire up images that opt-in
    const attachImageModal = () => {
        const projectImgs = isProjectDetailPage()
            ? Array.from(document.querySelectorAll('#project-hero, article img'))
            : [];

        const optInImgs = Array.from(document.querySelectorAll('img[data-full], img[data-modalable], img.modal-image, img.clickable-hero'));
        const imgs = Array.from(new Set([...projectImgs, ...optInImgs]));

        imgs.forEach((img) => {
            if (img.id === 'modal-img') return; // skip nested modal image if any
            img.classList.add('cursor-pointer');
            img.addEventListener('click', () => openModalForImage(img));
            if (!isTouch) {
                img.addEventListener('mouseenter', (e) => showTooltip(e));
                img.addEventListener('mousemove', (e) => moveTooltip(e));
                img.addEventListener('mouseleave', hideTooltip);
            }
        });
    };

    // Close handlers
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (prevBtn) prevBtn.addEventListener('click', showPrev);
    if (nextBtn) nextBtn.addEventListener('click', showNext);
    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
    }
    document.addEventListener('keydown', (e) => {
        if (!modal || modal.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowLeft' && galleryImages.length > 1) showPrev();
        if (e.key === 'ArrowRight' && galleryImages.length > 1) showNext();
    });

    // Tooltip helpers
    function showTooltip(e) {
        if (!tooltip || isTouch) return;
        tooltip.classList.remove('hidden');
        moveTooltip(e);
    }

    function moveTooltip(e) {
        if (!tooltip || isTouch) return;
        const padding = 12;
        let x = e.clientX + padding;
        let y = e.clientY + padding;
        const rect = tooltip.getBoundingClientRect();
        if (x + rect.width > window.innerWidth) x = e.clientX - rect.width - padding;
        if (y + rect.height > window.innerHeight) y = e.clientY - rect.height - padding;
        tooltip.style.left = x + 'px';
        tooltip.style.top = y + 'px';
    }

    function hideTooltip() {
        if (!tooltip) return;
        tooltip.classList.add('hidden');
    }

    // Attach after DOM is ready. If content is injected later, re-run attachImageModal.
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', attachImageModal);
    } else {
        attachImageModal();
    }
</script>
