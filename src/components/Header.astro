---
import { SITE } from "@/consts";

// compute initials from SITE.TITLE (first and last name initials)
const nameParts = SITE.TITLE.split(/\s+/).filter(Boolean);
const firstInitial = nameParts[0] ? nameParts[0].charAt(0) : "";
const lastInitial = nameParts.length > 1 ? nameParts[nameParts.length - 1].charAt(0) : "";
const initials = (firstInitial + (lastInitial ? "." + lastInitial : "")).toUpperCase();
const withBase = (path: string) => {
    const base = import.meta.env.BASE_URL.endsWith("/")
        ? import.meta.env.BASE_URL
        : `${import.meta.env.BASE_URL}/`;
    return `${base}${path.replace(/^\/+/, "")}`;
};

const links = [
    { name: "Home", href: withBase("/"), target: "_self" },
    { name: "About", href: withBase("/about"), target: "_self" },
    { name: "Work", href: withBase("/projects"), target: "_self" },
];
---

<header class="fixed top-0 w-full z-50">
    <div class="container mx-auto flex items-center justify-between p-6">
    <a href={withBase("/")} class="font-bold font-mono text-4xl">{initials}.</a>
        <nav class="space-x-3 text-secondary hidden md:block">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class="hover:border-b-2 hover:border-dashed hover:border-secondary pb-0.5"
                    >
                        {link.name}
                    </a>
                ))
            }
        </nav>
        <div class="flex items-center gap-3">
            <button id="theme-toggle" aria-label="Toggle color mode" aria-pressed="false" class="p-2 rounded hidden md:inline-flex" title="Toggle color mode">
                <svg id="theme-toggle-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle></svg>
            </button>
            <button
                id="menu-toggle"
                class="hamburger focus:outline-none flex md:hidden"
                aria-label="Toggle navigation"
            >
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
        </div>
    </div>
    <div
        id="menu-mobile"
        class="hidden md:hidden space-x-3 text-secondary bg-background backdrop-blur-2xl w-screen p-4"
    >
        <nav class="flex flex-col gap-4 text-2xl">
            <div class="flex justify-end">
                <button id="theme-toggle-mobile" aria-label="Toggle color mode" aria-pressed="false" class="p-2 rounded inline-flex" title="Toggle color mode">
                    <svg id="theme-toggle-icon-mobile" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle></svg>
                </button>
            </div>
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class="hover:border-b-2 hover:border-dashed hover:border-secondary pb-0.5"
                    >
                        {link.name}
                    </a>
                ))
            }
        </nav>
    </div>
</header>

<style>
    .hamburger {
        gap: 5px;
        cursor: pointer;
        position: relative;
        width: 24px;
        height: 21px;
        padding: 0;
        border: 0;
        background: transparent;
    }

    .hamburger-line {
        width: 24px;
        height: 3px;
        background-color: var(--color-secondary, #000000);
        transition: all 0.3s ease;
        position: absolute;
        left: 0;
    }

    .hamburger-line:nth-child(1) {
        top: 0;
    }

    .hamburger-line:nth-child(2) {
        top: 9px;
    }

    .hamburger-line:nth-child(3) {
        top: 18px;
    }

    .hamburger.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg);
        top: 9px;
    }

    .hamburger.active .hamburger-line:nth-child(2) {
        display: none;
        opacity: 0;
    }

    .hamburger.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg);
        top: 9px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const win = window as Window & { toggleTheme?: () => 'dark' | 'light' };
        const menuMobile = document.getElementById("menu-mobile");
        const toggle = document.getElementById("menu-toggle");
        toggle?.addEventListener("click", () => {
            menuMobile?.classList.toggle("hidden");
            toggle.classList.toggle("active");
            const expanded = toggle.classList.contains("active");
            toggle.setAttribute("aria-expanded", String(expanded));
        });

    // Theme toggle wiring (desktop + mobile)
    const themeBtn = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-toggle-icon');
    const themeBtnMobile = document.getElementById('theme-toggle-mobile');
    const themeIconMobile = document.getElementById('theme-toggle-icon-mobile');

        function updateThemeButton(){
            const isDark = document.documentElement.classList.contains('dark');
            if(themeBtn) {
                themeBtn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
                themeBtn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
                themeBtn.title = isDark ? 'Switch to light mode' : 'Switch to dark mode';
            }
            if(themeBtnMobile){
                themeBtnMobile.setAttribute('aria-pressed', isDark ? 'true' : 'false');
                themeBtnMobile.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
                themeBtnMobile.title = isDark ? 'Switch to light mode' : 'Switch to dark mode';
            }
            function setIcon(el: SVGElement | null){
                if(!el) return;
                if(isDark){
                    el.innerHTML = '<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" fill="currentColor" stroke="none"></path>';
                } else {
                    el.innerHTML = '\n                        <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle>\n                        <g stroke="currentColor" stroke-width="2" stroke-linecap="round">\n                          <path d="M12 2v2"></path>\n                          <path d="M12 20v2"></path>\n                          <path d="M4.22 4.22l1.42 1.42"></path>\n                          <path d="M18.36 18.36l1.42 1.42"></path>\n                          <path d="M2 12h2"></path>\n                          <path d="M20 12h2"></path>\n                          <path d="M4.22 19.78l1.42-1.42"></path>\n                          <path d="M18.36 5.64l1.42-1.42"></path>\n                        </g>';
                }
            }
            setIcon(themeIcon as SVGElement | null);
            setIcon(themeIconMobile as SVGElement | null);
        }

        if(themeBtn){
            themeBtn.addEventListener('click', () => {
                win.toggleTheme?.();
                updateThemeButton();
            });
        }
        if(themeBtnMobile){
            themeBtnMobile.addEventListener('click', () => {
                win.toggleTheme?.();
                updateThemeButton();
            });
        }
        // initialize
        updateThemeButton();
    });
</script>
