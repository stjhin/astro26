---
import Position from "@/components/Position.astro";
import Skills from "@/components/Skills.astro";

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, "")}`;
};
---

<section class="resume container mx-auto pt-18 p-6">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <h1 class="heading text-5xl md:text-9xl uppercase">
      Resume
    </h1>
    <a
      href={withBase("/Resume-Ju2026.pdf")}
      download
      class="w-full sm:w-auto flex items-center justify-center bg-primary rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-dashed hover:outline-secondary hover:text-foreground transition text-background font-mono font-bold"
    >
      Download Resume
    </a>
  </div>

  <div class="positions space-y-2 max-w-3xl">
    <Position
      company="Intelex"
      title="Product Designer — EHSQ Industry"
      date="2022–2026"
    />
    <Position
      company="Acid Integrations"
      title="UX Designer — Consultancy"
      date="2018–2022"
    />
  </div>
  <hr class="my-16 border-secondary/30" />

  <Skills headingLevel={2} />
</section>
