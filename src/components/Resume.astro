---
import Position from "@/components/Position.astro";
import Skills from "@/components/Skills.astro";

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, "")}`;
};
---

<section class="resume container mx-auto pt-18 p-6">
  <div
    class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8"
  >
    <h1 class="heading text-5xl md:text-9xl uppercase">Resume</h1>
    <a
      href={withBase("/Resume-Ju2026.pdf")}
      download
      class="w-full sm:w-auto flex items-center justify-center bg-primary rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-dashed hover:outline-secondary hover:text-foreground transition text-background font-mono font-bold"
    >
      Download Resume
    </a>
  </div>

  <div class="positions space-y-2">
    <Position
      company="Intelex"
      title="Product Designer — Design Systems"
      description="Scalable, AI-integrated design systems for the whole ecosystem & acquisition integration."
      date="2022–2026"
    >
      <ul class="description text-tertiary text-xs md:text-sm list-disc pl-5 space-y-1">
        <li>Built a design system from scratch that rebuilt ACTS, an acquired product, into the Intelex ecosystem — unifying two products into a single experience</li>
        <li>Serves 100+ surfaces, 40+ applications, and 100+ engineers across the organization</li>
        <li>Reduced component creation time by 80% with AI-assisted Figma-to-Storybook pipeline using MCP automation</li>
        <li>Drove 80% adoption across 10+ product teams — cutting developer handoff questions by 70%</li>
        <li>Redesigned core compliance workflows — reducing task completion time by ~35% and cutting support tickets by ~40%</li>
      </ul>
    </Position>
    <Position
      company="Acid Integrations"
      title="UX Designer — Consultancy"
      description="0-to-1 product launch for early-stage startups."
      date="2018–2022"
    >
      <ul class="description text-tertiary text-xs md:text-sm list-disc pl-5 space-y-1">
        <li>Led end-to-end design for multiple MVPs — from research to shipped products</li>
        <li>Reduced iteration cycles by 50% with lightweight research and experimentation frameworks</li>
      </ul>
    </Position>
  </div>
  <hr class="my-16 border-secondary/30" />

  <Skills headingLevel={2} />
</section>
