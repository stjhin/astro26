---
import { SITE } from "@/consts";
const withBase = (path: string) => {
    const base = import.meta.env.BASE_URL.endsWith("/")
        ? import.meta.env.BASE_URL
        : `${import.meta.env.BASE_URL}/`;
    return `${base}${path.replace(/^\/+/, "")}`;
};
---

<section
    class="grid grid-cols-1 lg:grid-cols-2 items-center container mx-auto min-h-screen p-6 md:gap-16 gap-8 pt-18"
>
    <h1 class="heading text-[clamp(4rem,12vw,8rem)] uppercase">
        {SITE.TITLE}
    </h1>
    <div class="space-y-8">
        <p class="text-2xl text-secondary">
            {SITE.DESCRIPTION}
        </p>
        <div class="flex flex-col md:flex-row gap-2.5">
            <a
                class="w-full sm:w-auto flex items-center justify-center bg-primary rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-dashed hover:outline-secondary hover:text-foreground transition text-background"
                href={withBase("/projects")}>View Work</a
            >
            <a
                class="w-full sm:w-auto flex items-center justify-center bg-foreground text-background rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-dashed hover:outline-secondary hover:text-foreground transition"
                href="https://drive.google.com/file/d/1XN80FbybY8vSbWDNBZfreZGZWgx_Etdu/view?usp=sharing">Resume</a
            >
        </div>
    </div>
</section>
