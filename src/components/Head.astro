---
import "@/styles/global.css";
import { Font } from "astro:assets";

interface Props {
    title: string;
    description: string;
    image?: string;
}

const withBase = (path: string) => {
    const base = import.meta.env.BASE_URL.endsWith("/")
        ? import.meta.env.BASE_URL
        : `${import.meta.env.BASE_URL}/`;
    return `${base}${path.replace(/^\/+/, "")}`;
};
const { title, description, image = withBase("/placeholder.png") } = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" href={withBase("/favicon.ico")} />
<link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32x32.png")} />
<link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16x16.png")} />
<link rel="apple-touch-icon" href={withBase("/favicon-32x32.png")} />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- fonts -->
<!-- Theme preloader: apply saved theme before paint to avoid flash -->
<script>
(function(){
    const win = window as Window & { toggleTheme?: () => 'dark' | 'light' };
    const storageKey = 'site-theme';
    const className = 'dark';
    function apply(t: 'dark' | 'light'){
        if(t==='dark') document.documentElement.classList.add(className);
        else document.documentElement.classList.remove(className);
    }
    const saved = (function(){ try{ return localStorage.getItem(storageKey) }catch(e){return null} })();
    if(saved === 'dark' || saved === 'light'){ apply(saved); }
    else {
        // Default first visit to dark mode when no preference has been saved yet.
        apply('dark');
    }
    win.toggleTheme = function(){
        const html = document.documentElement;
        const isDark = html.classList.toggle(className);
        try{ localStorage.setItem(storageKey, isDark ? 'dark' : 'light'); }catch(e){}
        return isDark ? 'dark' : 'light';
    };
})();
</script>
<Font cssVariable="--font-mono" preload />
<Font cssVariable="--font-sans" preload />
