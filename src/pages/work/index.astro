---
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { WORK } from "@/consts";

const allWork: CollectionEntry<"work">[] =
    await getCollection("work");
---

<Layout title={WORK.TITLE} description={WORK.DESCRIPTION}>
    <section id="Work" class="container mx-auto px-6 pt-18">
        <h1 class="heading text-5xl md:text-9xl uppercase mr-4 md:mr-8 my-8">
            work
        </h1>
        {allWork.map((item) => <Card entry={item} />)}
    </section>
</Layout>
